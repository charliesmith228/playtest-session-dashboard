{
    "name": "charliesmith228/playtest-session-dashboard-api",
    "description": "The API backend for my local playtest session dashboard side project.",
    "version": "1",
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Migrator\\": "migrator/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "charliesmith228",
            "email": "charliesmith228@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "firebase/php-jwt": "^7.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "pestphp/pest": "^4.7"
    },
    "scripts": {
        "cs-check": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fix": "./vendor/bin/php-cs-fixer fix",
        "stan": "./vendor/bin/phpstan analyse migrator public src migrate.php routes.php",
        "test": "./vendor/bin/pest",
        "check": [
            "composer audit",
            "@cs-check",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
